# Modelo de configuração. Copie para `.env` e preencha.
# O `.env` real NUNCA vai pro git (já está no .gitignore).

# === Banco (V1: SQLite local) ===
# Caminho do arquivo SQLite usado na primeira fatia.
DATABASE_URL=sqlite:///./precos.db

# === Mercado Livre (coletor V1) ===
# Só preencher se a API de busca exigir token de acesso.
# ML_ACCESS_TOKEN=

# === Serper — Google Shopping (coletor de comparação real) ===
# Chave grátis (2.500 buscas) em https://serper.dev — SECRETA, nunca no git.
# SERPER_API_KEY=

# === Config da conta (V1: 1 conta fixa) ===
# CEP destino para cotar frete. Sem CEP, compara sem frete (RN09).
CEP_DESTINO=
# Fontes de cashback que você tem direito, separadas por vírgula (RN14). Ex.: inter,meliuz
CASHBACK_ELEGIVEL=

# === Supabase (V2 — nuvem; ainda não usado no V1) ===
# SUPABASE_URL=
# SUPABASE_ANON_KEY=            # pública, protegida por RLS — pode ir no frontend
# SUPABASE_SERVICE_ROLE_KEY=    # SECRETA — só no worker/backend, ignora RLS, nunca no frontend

# === E-mail / SMTP (V2 — alertas; ainda não usado no V1) ===
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASSWORD=
